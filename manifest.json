{
  "manifest_version": 3,
  "name": "Google Forms AutoFiller",
  "version": "1.0",
  "description": "Autofills Google Forms with saved details (Name, Email, Contact, etc.). Works exclusively on Google Forms.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Setup Autofill Details"
  },
  "content_scripts": [
    {
      "matches": ["*://docs.google.com/forms/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://docs.google.com/forms/*"
  ]
}
